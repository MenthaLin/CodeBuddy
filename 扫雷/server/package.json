{
  "name": "minesweeper-server",
  "version": "1.0.0",
  "description": "扫雷游戏后端服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:game": "node ../tests/game.test.js",
    "test:api": "node ../tests/api.test.js",
    "test:board": "node ../tests/board.test.js",
    "test:all": "node ../tests/game.test.js && node ../tests/board.test.js && node ../tests/api.test.js",
    "test:coverage": "jest --config jest.config.js --coverage"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
